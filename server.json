    "url": "https://github.com/newrelic-partners/mcp-server-manifest",
    "source": "New Relic"
  },
  "runtime": {
    "type": "http",
    "url": "https://mcp.newrelic.com/mcp/",
    "headers": {
      "api-key": "NRAK-****",
      "include-tags": "discovery,alerting"
    }
  }
}